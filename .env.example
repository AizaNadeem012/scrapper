# Copy this file to .env and fill in real values
LOVABLE_API_KEY=your_lovable_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Optional if you want to use Vite-style names as well
# VITE_LOVABLE_API_KEY=your_lovable_api_key_here
# VITE_FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Free-tier option: Brave Search API (no Firecrawl needed)
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here
# VITE_BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Supabase values are also required for the app to save runs/results
SUPABASE_URL=your_supabase_url_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
